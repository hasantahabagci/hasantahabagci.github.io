---
export interface Props {
  items: Array<{
    title: string;
    organization: string;
    date: string;
    description?: string;
    location?: string;
    achievements?: string[];
  }>;
}

const { items } = Astro.props;
---

<div class="relative">
  <!-- Timeline line -->
  <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-300 dark:bg-gray-700"></div>
  
  <div class="space-y-8">
    {items.map((item) => (
      <div class="relative pl-12">
        <!-- Timeline dot -->
        <div class="absolute left-0 top-1 w-8 h-8 rounded-full bg-primary-500 border-4 border-white dark:border-gray-900 flex items-center justify-center">
          <div class="w-3 h-3 rounded-full bg-white"></div>
        </div>
        
        <!-- Content -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 hover:shadow-xl transition-shadow duration-300">
          <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-2">
            <div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-1">
                {item.title}
              </h3>
              <p class="text-primary-600 dark:text-primary-400 font-medium">
                {item.organization}
              </p>
            </div>
            <div class="mt-2 md:mt-0 text-sm text-gray-600 dark:text-gray-400">
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                {item.date}
              </div>
              {item.location && (
                <div class="flex items-center gap-1 mt-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  {item.location}
                </div>
              )}
            </div>
          </div>
          
          {item.description && (
            <p class="text-gray-700 dark:text-gray-300 mt-3">
              {item.description}
            </p>
          )}
          
          {item.achievements && item.achievements.length > 0 && (
            <ul class="mt-4 space-y-2">
              {item.achievements.map((achievement) => (
                <li class="flex items-start gap-2 text-gray-700 dark:text-gray-300">
                  <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span>{achievement}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
