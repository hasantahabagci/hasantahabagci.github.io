---
export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  image?: string;
  tags?: string[];
  link?: string;
}

const { title, subtitle, description, image, tags, link } = Astro.props;
---

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300 overflow-hidden h-full flex flex-col">
  {image && (
    <div class="h-48 overflow-hidden">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}
  
  <div class="p-6 flex-grow flex flex-col">
    <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-gray-100">
      {link ? (
        <a href={link} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          {title}
        </a>
      ) : (
        title
      )}
    </h3>
    
    {subtitle && (
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">{subtitle}</p>
    )}
    
    {description && (
      <p class="text-gray-700 dark:text-gray-300 mb-4 flex-grow">{description}</p>
    )}
    
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-auto">
        {tags.map((tag) => (
          <span class="px-3 py-1 bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 text-xs rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
