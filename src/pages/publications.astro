---
import MainLayout from '../layouts/MainLayout.astro';

const publications = [
  {
    title: "Advanced Machine Learning Techniques for Distributed Systems",
    authors: "H. T. Bagci, Co-Author A., Co-Author B.",
    venue: "International Conference on Machine Learning (ICML)",
    year: "2023",
    type: "Conference Paper",
    link: "#",
    abstract: "This paper presents novel approaches to applying machine learning in distributed computing environments..."
  },
  {
    title: "Optimizing Web Application Performance Through Modern Architecture Patterns",
    authors: "H. T. Bagci, Co-Author C.",
    venue: "Journal of Software Engineering",
    year: "2022",
    type: "Journal Article",
    link: "#",
    abstract: "An in-depth analysis of modern web architecture patterns and their impact on application performance..."
  },
  {
    title: "Scalable Microservices: Design Patterns and Best Practices",
    authors: "H. T. Bagci",
    venue: "IEEE Software",
    year: "2022",
    type: "Magazine Article",
    link: "#",
    abstract: "A comprehensive guide to designing and implementing scalable microservices architectures..."
  },
];
---

<MainLayout 
  title="Publications - Hasan Tahaba Bagci"
  description="Research publications and academic contributions by Hasan Tahaba Bagci"
>
  <div class="bg-white dark:bg-gray-900">
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-primary-50 to-blue-50 dark:from-gray-800 dark:to-gray-900 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 mb-4">
          <svg class="w-12 h-12 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100">
            Publications
          </h1>
        </div>
        <p class="text-xl text-gray-600 dark:text-gray-400">
          Research papers and academic contributions
        </p>
      </div>
    </section>

    <!-- Publications List -->
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="space-y-8">
          {publications.map((pub, index) => (
            <article class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 hover:shadow-xl transition-shadow">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex-grow">
                  <span class="inline-block px-3 py-1 bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 text-xs rounded-full mb-3">
                    {pub.type}
                  </span>
                  <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">
                    {pub.link !== "#" ? (
                      <a href={pub.link} target="_blank" rel="noopener noreferrer" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                        {pub.title}
                      </a>
                    ) : (
                      pub.title
                    )}
                  </h2>
                  <p class="text-gray-600 dark:text-gray-400 mb-2">
                    {pub.authors}
                  </p>
                  <p class="text-sm text-gray-500 dark:text-gray-500 mb-4">
                    <span class="font-medium">{pub.venue}</span> • {pub.year}
                  </p>
                </div>
                <div class="text-3xl font-bold text-primary-200 dark:text-primary-800">
                  {String(index + 1).padStart(2, '0')}
                </div>
              </div>
              
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                {pub.abstract}
              </p>
              
              {pub.link !== "#" && (
                <div class="mt-4">
                  <a 
                    href={pub.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-medium transition-colors"
                  >
                    Read Full Paper
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </a>
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Research Interests -->
    <section class="py-16 bg-gray-50 dark:bg-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold mb-8 text-center text-gray-900 dark:text-gray-100">
          Research Interests
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white dark:bg-gray-900 rounded-lg p-6 text-center">
            <h3 class="font-semibold text-lg mb-2 text-gray-900 dark:text-gray-100">Machine Learning</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">Deep learning and neural networks</p>
          </div>
          
          <div class="bg-white dark:bg-gray-900 rounded-lg p-6 text-center">
            <h3 class="font-semibold text-lg mb-2 text-gray-900 dark:text-gray-100">Distributed Systems</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">Scalable architecture design</p>
          </div>
          
          <div class="bg-white dark:bg-gray-900 rounded-lg p-6 text-center">
            <h3 class="font-semibold text-lg mb-2 text-gray-900 dark:text-gray-100">Cloud Computing</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">Infrastructure and optimization</p>
          </div>
          
          <div class="bg-white dark:bg-gray-900 rounded-lg p-6 text-center">
            <h3 class="font-semibold text-lg mb-2 text-gray-900 dark:text-gray-100">Software Engineering</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">Best practices and patterns</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>
