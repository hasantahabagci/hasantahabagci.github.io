---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/Card.astro';

const projects = [
  {
    title: "E-Commerce Platform",
    subtitle: "Full-Stack Web Application",
    description: "A complete e-commerce solution with user authentication, product management, shopping cart, and payment integration. Built with modern technologies for optimal performance.",
    tags: ["React", "Node.js", "MongoDB", "Stripe"],
    link: "https://github.com/hasantahabagci"
  },
  {
    title: "Task Management System",
    subtitle: "Productivity Tool",
    description: "Collaborative task management application with real-time updates, team collaboration features, and advanced filtering options.",
    tags: ["Vue.js", "Firebase", "Tailwind CSS"],
    link: "https://github.com/hasantahabagci"
  },
  {
    title: "Machine Learning Model",
    subtitle: "Research Project",
    description: "Developed a predictive model for data analysis using advanced machine learning algorithms. Achieved 95% accuracy on test dataset.",
    tags: ["Python", "TensorFlow", "Scikit-learn"],
    link: "https://github.com/hasantahabagci"
  },
  {
    title: "API Gateway Service",
    subtitle: "Microservices Architecture",
    description: "Built a scalable API gateway service to handle routing, authentication, and rate limiting for microservices architecture.",
    tags: ["Go", "Docker", "Kubernetes", "Redis"],
    link: "https://github.com/hasantahabagci"
  },
  {
    title: "Mobile Weather App",
    subtitle: "Cross-Platform Application",
    description: "A beautiful weather application with real-time forecasts, location-based updates, and interactive weather maps.",
    tags: ["React Native", "TypeScript", "Weather API"],
    link: "https://github.com/hasantahabagci"
  },
  {
    title: "DevOps Automation Tool",
    subtitle: "CI/CD Pipeline",
    description: "Automated deployment tool for streamlining the development workflow. Reduced deployment time by 70%.",
    tags: ["Python", "GitHub Actions", "AWS"],
    link: "https://github.com/hasantahabagci"
  },
];
---

<MainLayout 
  title="Projects - Hasan Tahaba Bagci"
  description="Featured projects and contributions by Hasan Tahaba Bagci"
>
  <div class="bg-white dark:bg-gray-900">
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-primary-50 to-blue-50 dark:from-gray-800 dark:to-gray-900 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 mb-4">
          <svg class="w-12 h-12 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100">
            Projects
          </h1>
        </div>
        <p class="text-xl text-gray-600 dark:text-gray-400">
          A showcase of my work and contributions
        </p>
      </div>
    </section>

    <!-- Projects Grid -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projects.map((project) => (
            <Card {...project} />
          ))}
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-16 bg-gray-50 dark:bg-gray-800">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4 text-gray-900 dark:text-gray-100">
          More on GitHub
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
          Check out more of my projects and contributions on GitHub. I'm always working on something new!
        </p>
        <a 
          href="https://github.com/hasantahabagci" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors shadow-lg hover:shadow-xl font-medium"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View GitHub Profile
        </a>
      </div>
    </section>
  </div>
</MainLayout>
