---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout 
  title="About - Hasan Tahaba Bagci"
  description="Learn more about Hasan Tahaba Bagci, background, interests, and professional journey"
>
  <div class="bg-white dark:bg-gray-900">
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-primary-50 to-blue-50 dark:from-gray-800 dark:to-gray-900 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">
          About Me
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-400">
          Get to know more about my background, interests, and professional journey
        </p>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Profile Section -->
          <div class="lg:col-span-1">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 sticky top-24">
              <div class="w-48 h-48 mx-auto mb-6 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white text-6xl font-bold shadow-xl">
                HTB
              </div>
              <h2 class="text-2xl font-bold text-center mb-2 text-gray-900 dark:text-gray-100">
                Hasan Tahaba Bagci
              </h2>
              <p class="text-center text-gray-600 dark:text-gray-400 mb-6">
                Software Engineer & Researcher
              </p>
              
              <div class="space-y-3 text-sm">
                <div class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <span>Location</span>
                </div>
                
                <div class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <a href="mailto:contact@example.com" class="hover:text-primary-600 dark:hover:text-primary-400">
                    contact@example.com
                  </a>
                </div>
                
                <div class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                  <svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  <a href="https://github.com/hasantahabagci" target="_blank" rel="noopener noreferrer" class="hover:text-primary-600 dark:hover:text-primary-400">
                    GitHub
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Bio Section -->
          <div class="lg:col-span-2 space-y-8">
            <div class="prose dark:prose-invert max-w-none">
              <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-gray-100">
                Hello! 👋
              </h2>
              
              <div class="text-gray-700 dark:text-gray-300 space-y-4">
                <p class="text-lg leading-relaxed">
                  I'm a passionate software engineer and researcher with a strong interest in building innovative solutions that make a difference. My journey in technology has been driven by curiosity and a desire to solve complex problems.
                </p>
                
                <p class="text-lg leading-relaxed">
                  With experience spanning multiple domains, I specialize in developing scalable applications, conducting research in emerging technologies, and contributing to open-source projects. I believe in continuous learning and staying updated with the latest technological advancements.
                </p>
                
                <p class="text-lg leading-relaxed">
                  When I'm not coding or researching, I enjoy exploring new technologies, contributing to the developer community, and sharing knowledge through publications and presentations.
                </p>
              </div>
            </div>

            <!-- Interests -->
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8">
              <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">
                Interests & Focus Areas
              </h2>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <h3 class="font-semibold text-gray-900 dark:text-gray-100">Web Development</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Building modern, responsive web applications</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <h3 class="font-semibold text-gray-900 dark:text-gray-100">Software Engineering</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Designing scalable and maintainable systems</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <h3 class="font-semibold text-gray-900 dark:text-gray-100">Research</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Exploring innovative solutions to technical challenges</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-primary-500 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <h3 class="font-semibold text-gray-900 dark:text-gray-100">Open Source</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Contributing to community projects</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Call to Action -->
            <div class="bg-gradient-to-br from-primary-50 to-blue-50 dark:from-primary-900/20 dark:to-blue-900/20 rounded-lg p-8 border border-primary-100 dark:border-primary-800">
              <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100">
                Let's Connect!
              </h2>
              <p class="text-gray-700 dark:text-gray-300 mb-6">
                I'm always interested in discussing new projects, creative ideas, or opportunities to be part of your visions.
              </p>
              <a 
                href="/contact" 
                class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors shadow-lg hover:shadow-xl font-medium"
              >
                Get in Touch
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>
