---
import MainLayout from '../layouts/MainLayout.astro';
import Timeline from '../components/Timeline.astro';

const experience = [
  {
    title: "Senior Software Engineer",
    organization: "Tech Company Inc.",
    date: "2022 - Present",
    location: "Remote",
    description: "Leading development of scalable web applications and mentoring junior developers. Working with modern technologies and cloud infrastructure.",
    achievements: [
      "Architected and implemented microservices infrastructure serving 1M+ users",
      "Reduced deployment time by 60% through CI/CD pipeline optimization",
      "Led team of 5 developers in agile environment",
      "Introduced best practices for code review and testing"
    ]
  },
  {
    title: "Software Engineer",
    organization: "Innovation Labs",
    date: "2020 - 2022",
    location: "City, Country",
    description: "Developed and maintained multiple client-facing applications. Collaborated with cross-functional teams to deliver high-quality software solutions.",
    achievements: [
      "Built RESTful APIs serving 500K+ daily requests",
      "Improved application performance by 40% through optimization",
      "Implemented automated testing reducing bugs by 35%",
      "Contributed to open-source projects used by the team"
    ]
  },
  {
    title: "Junior Developer",
    organization: "StartUp Ventures",
    date: "2019 - 2020",
    location: "City, Country",
    description: "Worked on various features for the company's flagship product. Gained experience in full-stack development and agile methodologies.",
    achievements: [
      "Developed new features adopted by 10K+ users",
      "Fixed critical bugs improving system stability",
      "Participated in code reviews and team standups",
      "Learned modern development practices and tools"
    ]
  },
];
---

<MainLayout 
  title="Experience - Hasan Tahaba Bagci"
  description="Professional work experience and career journey of Hasan Tahaba Bagci"
>
  <div class="bg-white dark:bg-gray-900">
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-primary-50 to-blue-50 dark:from-gray-800 dark:to-gray-900 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 mb-4">
          <svg class="w-12 h-12 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100">
            Experience
          </h1>
        </div>
        <p class="text-xl text-gray-600 dark:text-gray-400">
          My professional journey and work experience
        </p>
      </div>
    </section>

    <!-- Experience Timeline -->
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <Timeline items={experience} />
      </div>
    </section>

    <!-- Skills Summary -->
    <section class="py-16 bg-gray-50 dark:bg-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold mb-12 text-center text-gray-900 dark:text-gray-100">
          Key Responsibilities & Technologies
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 text-center hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 mx-auto bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900 dark:text-gray-100">
              Full-Stack Development
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Building complete web applications from frontend to backend
            </p>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 text-center hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 mx-auto bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900 dark:text-gray-100">
              Cloud Infrastructure
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Deploying and managing applications on cloud platforms
            </p>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 text-center hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 mx-auto bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900 dark:text-gray-100">
              Team Leadership
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Leading teams and mentoring junior developers
            </p>
          </div>

          <div class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 text-center hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 mx-auto bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900 dark:text-gray-100">
              Agile Methodology
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Working in agile teams with sprint-based development
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>
